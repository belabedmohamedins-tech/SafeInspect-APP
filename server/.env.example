# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Railway / Render / Supabase / local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/safeinspect?schema=public"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Strong random secret — generate with: openssl rand -hex 64
JWT_SECRET="CHANGE_ME_use_openssl_rand_hex_64"
# Token expiry (e.g. 30d, 7d, 1h)
JWT_EXPIRES_IN="30d"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
# Comma-separated list of allowed origins (your Expo dev URL + production)
CORS_ORIGINS="http://localhost:8081,https://your-production-domain.com"

# ── Expo Push Notifications ───────────────────────────────────────────────────
# No secret needed — Expo push API is public; the SDK uses device tokens only
# Leave blank unless you need Enhanced Credentials (paid Expo plan)
EXPO_ACCESS_TOKEN=""
