{
  "name": "dz-inspection",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall":   "node -e \"const fs=require('fs');try{const p=require('./node_modules/expo-modules-core/package.json');if(p.main&&p.main.includes('src/index.ts')){p.main='build/index.js';fs.writeFileSync('./node_modules/expo-modules-core/package.json',JSON.stringify(p,null,2));console.log('patched expo-modules-core');}}catch(e){}\"",
    "start":         "cross-env NODE_OPTIONS=\"--import tsx/esm --no-experimental-strip-types\" expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android":       "cross-env NODE_OPTIONS=\"--import tsx/esm --no-experimental-strip-types\" expo start --android",
    "ios":           "cross-env NODE_OPTIONS=\"--import tsx/esm --no-experimental-strip-types\" expo start --ios",
    "web":           "cross-env NODE_OPTIONS=\"--import tsx/esm --no-experimental-strip-types\" expo start --web",
    "lint":          "expo lint",
    "test":          "cross-env NODE_OPTIONS=\"--no-experimental-strip-types\" node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests",
    "test:coverage": "cross-env NODE_OPTIONS=\"--no-experimental-strip-types\" node --experimental-vm-modules node_modules/.bin/jest --coverage --passWithNoTests"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/datetimepicker": "8.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "expo": "~52.0.46",
    "expo-constants": "~17.0.8",
    "expo-crypto": "~13.0.2",
    "expo-document-picker": "~12.0.2",
    "expo-file-system": "~18.0.12",
    "expo-local-authentication": "~14.0.1",
    "expo-notifications": "~0.29.14",
    "expo-print": "~14.0.3",
    "expo-router": "~4.0.20",
    "expo-secure-store": "~13.0.2",
    "expo-sharing": "~13.0.1",
    "expo-splash-screen": "~0.29.22",
    "expo-status-bar": "~2.0.1",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-reanimated": "~3.16.7",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/runtime": "^7.25.0",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.3.12",
    "@types/react-test-renderer": "^18.3.0",
    "babel-jest": "^29.7.0",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.6",
    "react-test-renderer": "18.3.1",
    "tsx": "^4.19.4",
    "typescript": "~5.3.3"
  }
}
